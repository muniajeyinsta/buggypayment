PORT=3000

# Razorpay Checkout
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here

# Supabase (required for user / subscription storage)
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Server: prefer service role key (Settings → API → service_role) so RLS is not blocking.
# Never expose service_role in frontend. For local dev only, anon key works if RLS allows the operations.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Dev-only: GET /api/debug/a4dcb6
# BUGGY_DEBUG_API=1
