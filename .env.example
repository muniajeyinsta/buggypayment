NODE_ENV=development
PORT=3000

# Optional comma-separated or single origin
CORS_ORIGIN=

# Razorpay (server only)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Optional tuning (defaults are production-safe)
# REQUEST_TIMEOUT_MS=12000
# DB_READ_TIMEOUT_MS=2000
# DB_WRITE_TIMEOUT_MS=8000
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_PAYMENT_MAX=20

# Dev: after start, open the API root in the default browser (optional)
# BUGGY_OPEN_BROWSER=1
