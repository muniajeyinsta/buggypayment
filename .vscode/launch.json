{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start EV Buggy server (opens Pay when ready)",
      "program": "${workspaceFolder}/server/index.js",
      "cwd": "${workspaceFolder}",
      "env": { "BUGGY_DEBUG_API": "1" },
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "pattern": "server listening on http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s/pay?userid=A001",
        "action": "openExternally"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open Pay page only (server already running)",
      "url": "http://localhost:3000/pay?userid=A001",
      "webRoot": "${workspaceFolder}/public"
    }
  ]
}
